rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if user profile exists
    function userProfileExists() {
      return exists(/databases/$(database)/documents/artifacts/$(appId)/users/$(request.auth.uid)/user_config/profile);
    }

    // Get user role - returns null if profile doesn't exist
    function getUserRole() {
      // Only try to get role if profile exists
      return userProfileExists() 
        ? get(/databases/$(database)/documents/artifacts/$(appId)/users/$(request.auth.uid)/user_config/profile).data.role
        : null;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isStaff() {
      return isAuthenticated() && getUserRole() == 'staff';
    }

    function isAdminOrStaff() {
      return isAdmin() || isStaff();
    }

    // --- Data Security Rules ---
    match /artifacts/{appId} {
      
      // Public config - readable by anyone, writable by admin or authenticated user (for first setup)
      match /public/config {
        allow read: if true;
        allow write: if isAdmin() || (isAuthenticated() && !userProfileExists()); // Allow admin or first-time setup
      }
      
      // Master stock list - readable by authenticated users, writable by admin
      match /public/master_stock_list {
        allow read: if isAuthenticated();
        allow write: if isAdmin() || (isAuthenticated() && !userProfileExists()); // Allow admin or first-time setup
      }
      
      // Public data collections
      match /public/data {
        
        // Stores - readable by all authenticated, writable by admin only
        match /stores/{storeId} {
          allow read: if isAuthenticated();
          allow write: if isAdmin() || (isAuthenticated() && !userProfileExists()); // Allow admin or first-time setup
        }

        // Stock entries - readable by all authenticated, writable by admin OR staff
        match /stock_entries/{entryId} {
          allow read: if isAuthenticated();
          // Allow write if: admin, staff, OR authenticated user without profile (first-time access)
          allow write: if isAdmin() || isStaff() || (isAuthenticated() && !userProfileExists());
        }

        // Orders - readable by all authenticated, writable by admin OR staff, delete by admin only
        match /orders/{orderId} {
          allow read: if isAuthenticated();
          allow write: if isAdmin() || isStaff() || (isAuthenticated() && !userProfileExists());
          allow delete: if isAdmin() || (isAuthenticated() && !userProfileExists());
        }
      }
      
      // User profiles - users can read/write their own, admins can read all
      match /users/{userId}/{document=**} {
        allow read: if request.auth.uid == userId || isAdmin() || (isAuthenticated() && !userProfileExists());
        allow write: if request.auth.uid == userId || isAdmin() || (isAuthenticated() && !userProfileExists());
      }
    }
  }
}
