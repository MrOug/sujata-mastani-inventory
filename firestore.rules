rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      // This function securely gets the profile data for the currently logged-in user.
      // Returns null if profile doesn't exist instead of throwing an error
      let userProfile = get(/databases/$(database)/documents/artifacts/$(appId)/users/$(request.auth.uid)/user_config/profile);
      return userProfile != null ? userProfile.data : null;
    }

    function getRole() {
      // Safely get user role, returns null if not found
      let userData = getUserData();
      return userData != null && userData.role != null ? userData.role : null;
    }

    function isAdmin() {
      return isAuthenticated() && getRole() == 'admin';
    }

    function isStaff() {
      return isAuthenticated() && getRole() == 'staff';
    }

    // --- Data Security Rules ---
    match /artifacts/{appId} {
      
      // The public config document is readable by anyone to check if setup is done.
      // Only the first admin can write to it.
      match /public/config {
        allow read: if true;
        allow write: if isAdmin();
      }
      
      // Allow authenticated users to read and write the master stock list
      match /public/master_stock_list {
        allow read, write: if isAuthenticated();
      }
      
      // This matches the "data" document that holds our subcollections.
      match /public/data {

        // Rules for the 'stores' subcollection (e.g., /public/data/stores/{storeId})
        match /stores/{storeId} {
          allow read: if isAuthenticated();    // Any logged-in user can see the store list.
          allow write: if isAdmin();           // ONLY admins can create or delete stores.
        }

        // Rules for the 'stock_entries' subcollection (e.g., /public/data/stock_entries/{entryId})
        match /stock_entries/{entryId} {
          allow read: if isAuthenticated();    // Any logged-in user can read stock entries (for reports).
          // Allow write for authenticated users
          // Note: Role checking is done in app logic. If user profile doesn't exist, this allows the save
          // to prevent blocking legitimate saves. The app ensures profiles are created on login.
          allow write: if isAuthenticated();
        }

        // Rules for the 'orders' subcollection (e.g., /public/data/orders/{orderId})
        match /orders/{orderId} {
          allow read: if isAuthenticated();    // Any logged-in user can read orders (for order history).
          // Allow write for authenticated users (role check done in app logic)
          allow write: if isAuthenticated();
          allow delete: if isAdmin();           // ONLY admins can delete orders.
        }
      }
      
      // Rules for user-specific private data
      match /users/{userId}/{documents=**} {
        // A user can only read or write their OWN data. Admins can also read user profiles.
        allow read: if request.auth.uid == userId || isAdmin();
        allow write: if request.auth.uid == userId;
      }
    }
  }
}