rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isAuthenticated() {
      return request.auth != null;
    }

    // --- Data Security Rules ---
    // Simplified approach: Allow all authenticated users to read/write
    // App-level code enforces role-based access (admin vs staff)
    match /artifacts/{appId} {
      
      // Public config - readable by anyone, writable by authenticated users
      match /public/config {
        allow read: if true;
        allow write: if isAuthenticated();
      }
      
      // Master stock list - readable/writable by authenticated users
      match /public/master_stock_list {
        allow read, write: if isAuthenticated();
      }
      
      // Public data collections
      match /public/data {
        
        // Stores - readable/writable by authenticated users (app enforces admin-only)
        match /stores/{storeId} {
          allow read, write: if isAuthenticated();
        }

        // Stock entries - readable/writable by authenticated users (app enforces admin+staff)
        match /stock_entries/{entryId} {
          allow read, write: if isAuthenticated();
        }

        // Orders - readable/writable by authenticated users (app enforces admin+staff)
        match /orders/{orderId} {
          allow read, write, delete: if isAuthenticated();
        }
      }
      
      // User profiles - readable/writable by authenticated users (app enforces admin-only for listing)
      match /users/{userId} {
        // Allow reading user documents (for collection queries)
        allow read: if isAuthenticated();
        // Allow reading/writing user subcollections/documents
        match /{document=**} {
          allow read, write: if isAuthenticated();
        }
      }
    }
  }
}
